{
	"name": "frontend",
	"$schema": "../../node_modules/nx/schemas/project-schema.json",
	"sourceRoot": "apps/frontend/src",
	"projectType": "application",
	"targets": {
		"dev": {
			"executor": "nx:run-commands",
			"options": {
				"command": "npm run dev",
				"cwd": "apps/frontend"
			}
		},
		"build": {
			"executor": "nx:run-commands",
			"options": {
				"command": "npm run build",
				"cwd": "apps/frontend"
			},
			"outputs": ["{projectRoot}/build"]
		},
		"preview": {
			"executor": "nx:run-commands",
			"options": {
				"command": "npm run preview",
				"cwd": "apps/frontend"
			},
			"dependsOn": ["build"]
		}
	}
}
